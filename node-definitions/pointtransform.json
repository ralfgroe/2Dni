{
  "id": "pointtransform",
  "label": "Point Transform",
  "category": "Transform",
  "description": "Select individual points of the input geometry and move them via sliders or by dragging in the viewport. Scale selected points from their geometric center.",
  "inputs": [
    { "id": "geometry_in", "label": "Geometry In", "type": "geometry", "required": true }
  ],
  "outputs": [
    { "id": "geometry_out", "label": "Geometry Out", "type": "geometry" }
  ],
  "parameters": [
    { "id": "point_offsets", "label": "Point Offsets", "type": "text", "default": "{}" },
    { "id": "scale_points", "label": "Scale Points", "type": "text", "default": "" },
    { "id": "offset_x", "label": "Offset X", "type": "number", "default": 0, "min": -500, "max": 500 },
    { "id": "offset_y", "label": "Offset Y", "type": "number", "default": 0, "min": -500, "max": 500 },
    { "id": "scale", "label": "Scale", "type": "number", "default": 1, "min": 0.1, "max": 5 }
  ],
  "runtime": "pointtransform"
}
