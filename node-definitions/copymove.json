{
  "id": "copymove",
  "label": "Copy Move",
  "category": "Transform",
  "description": "Creates multiple copies of the input geometry, each offset by a specified X and Y distance from the previous copy.",
  "inputs": [
    { "id": "geometry_in", "label": "Geometry In", "type": "geometry", "required": true }
  ],
  "outputs": [
    { "id": "geometry_out", "label": "Geometry Out", "type": "geometry" }
  ],
  "parameters": [
    { "id": "copies", "label": "Copies", "type": "number", "default": 1, "min": 0, "max": 50 },
    { "id": "offset_x", "label": "Offset X", "type": "number", "default": 50, "min": -500, "max": 500 },
    { "id": "offset_y", "label": "Offset Y", "type": "number", "default": 0, "min": -500, "max": 500 }
  ],
  "runtime": "copymove"
}
