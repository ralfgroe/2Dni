{
  "id": "strangeattractor",
  "label": "Strange Attractor",
  "category": "Geometry",
  "description": "Generates strange attractors as a dense point cloud (or connected path). Choose De Jong, Clifford, or Lorenz, then tune the coefficients. De Jong/Clifford use a, b, c, d; Lorenz uses a=sigma, b=rho, c=beta. Try the presets and nudge the coefficients for endless variations.",
  "inputs": [],
  "outputs": [
    { "id": "geometry_out", "label": "Geometry Out", "type": "geometry" }
  ],
  "parameters": [
    { "id": "type", "label": "Type", "type": "select", "default": "De Jong", "options": ["De Jong", "Clifford", "Lorenz"] },
    { "id": "preset", "label": "Preset", "type": "select", "default": "Custom", "options": ["Custom", "Classic", "Swirl", "Wings", "Web", "Ribbon"] },
    { "id": "a", "label": "a", "type": "number", "default": 1.4, "min": -5, "max": 5, "step": 0.001 },
    { "id": "b", "label": "b", "type": "number", "default": -2.3, "min": -5, "max": 5, "step": 0.001 },
    { "id": "c", "label": "c", "type": "number", "default": 2.4, "min": -5, "max": 5, "step": 0.001 },
    { "id": "d", "label": "d", "type": "number", "default": -2.1, "min": -5, "max": 5, "step": 0.001 },
    { "id": "iterations", "label": "Points", "type": "number", "default": 20000, "min": 500, "max": 100000, "step": 500 },
    { "id": "render", "label": "Render", "type": "select", "default": "Points", "options": ["Points", "Lines"] },
    { "id": "dot_size", "label": "Dot Size", "type": "number", "default": 1, "min": 0.1, "max": 12, "step": 0.1 },
    { "id": "scale", "label": "Scale", "type": "number", "default": 180, "min": 10, "max": 800, "step": 1 },
    { "id": "x", "label": "X", "type": "number", "default": 0, "min": -500, "max": 500 },
    { "id": "y", "label": "Y", "type": "number", "default": 0, "min": -500, "max": 500 },
    { "id": "color", "label": "Color", "type": "color", "default": "#000000" },
    { "id": "stroke_width", "label": "Line Width", "type": "number", "default": 0.5, "min": 0.1, "max": 5, "step": 0.1 }
  ],
  "runtime": "strangeattractor"
}
