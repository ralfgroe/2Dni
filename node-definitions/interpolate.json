{
  "id": "interpolate",
  "label": "Interpolate",
  "category": "Transform",
  "description": "Morphs between two input geometries by interpolating their path points. Creates smooth transitions between shapes.",
  "inputs": [
    { "id": "geometry_a", "label": "Shape A", "type": "geometry", "required": true },
    { "id": "geometry_b", "label": "Shape B", "type": "geometry", "required": true }
  ],
  "outputs": [
    { "id": "geometry_out", "label": "Geometry Out", "type": "geometry" }
  ],
  "parameters": [
    { "id": "blend", "label": "Blend", "type": "number", "default": 0.5, "min": 0, "max": 1 },
    { "id": "steps", "label": "Steps", "type": "number", "default": 1, "min": 1, "max": 20, "step": 1 }
  ],
  "runtime": "interpolate"
}
