{
  "id": "scatter",
  "label": "Scatter",
  "category": "Transform",
  "description": "Distributes copies of input geometry in various patterns. Optionally accepts a shape as a scatter field to constrain where copies are placed.",
  "inputs": [
    { "id": "geometry_in", "label": "Geometry In", "type": "geometry", "required": true },
    { "id": "scatter_field", "label": "Scatter Field", "type": "geometry", "required": false }
  ],
  "outputs": [
    { "id": "geometry_out", "label": "Geometry Out", "type": "geometry" }
  ],
  "parameters": [
    { "id": "pattern", "label": "Pattern", "type": "select", "default": "Random", "options": ["Random", "Grid", "Hex", "Radial", "Sunflower", "Poisson Disk", "Voronoi"] },
    { "id": "count", "label": "Count", "type": "number", "default": 25, "min": 1, "max": 4000 },
    { "id": "width", "label": "Width", "type": "number", "default": 400, "min": 10, "max": 2000 },
    { "id": "height", "label": "Height", "type": "number", "default": 400, "min": 10, "max": 2000 },
    { "id": "center_x", "label": "Center X", "type": "number", "default": 0, "min": -1000, "max": 1000 },
    { "id": "center_y", "label": "Center Y", "type": "number", "default": 0, "min": -1000, "max": 1000 },
    { "id": "seed", "label": "Seed", "type": "number", "default": 42, "min": 0, "max": 9999, "step": 1 },
    { "id": "random_scale", "label": "Random Scale", "type": "number", "default": 0, "min": 0, "max": 1, "step": 0.01 },
    { "id": "random_rotate", "label": "Random Rotate", "type": "number", "default": 0, "min": 0, "max": 360 },
    { "id": "scale_by_distance", "label": "Scale by Distance", "type": "number", "default": 0, "min": -1, "max": 1, "step": 0.01 },
    { "id": "spacing", "label": "Spacing", "type": "number", "default": 0, "min": 0, "max": 200, "step": 1 }
  ],
  "runtime": "scatter"
}
